TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
BLOTATO_API_KEY=your_blotato_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
LINKEDIN_ACCOUNT_ID=your_linkedin_account_id_here
INSTAGRAM_ACCOUNT_ID=your_instagram_account_id_here
FACEBOOK_ACCOUNT_ID=your_facebook_account_id_here

# Optional: KI-Modell für Post-Generierung (Standard wenn nicht gesetzt: meta-llama/llama-3.1-8b-instruct:free)
# Kostenlose Alternativen: google/gemma-3-9b-it:free, mistralai/mistral-7b-instruct:free
